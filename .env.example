# Kontaktformular – E-Mail-Versand (Resend)
# Ohne RESEND_API_KEY läuft das Formular im sicheren Demo-Modus (sendet nichts).

# API-Key von https://resend.com
RESEND_API_KEY=

# Verifizierte Absenderadresse (Domain muss bei Resend verifiziert sein)
CONTACT_FROM="Hoffmann · Vogel Rechtsanwälte <kanzlei@ihre-domain.de>"

# Optional: zentrale Kopie aller Anfragen
CONTACT_CC=

# Zentrales Postfach (Fallback / "Sonstiges")
CONTACT_TO_DEFAULT=info@ihre-domain.de

# Empfänger je Rechtsgebiet (zuständige Person)
CONTACT_TO_MEDIZINSTRAFRECHT=medizinstrafrecht@ihre-domain.de
CONTACT_TO_WIRTSCHAFTSSTRAFRECHT=wirtschaftsstrafrecht@ihre-domain.de
CONTACT_TO_STEUERSTRAFRECHT=steuerstrafrecht@ihre-domain.de
